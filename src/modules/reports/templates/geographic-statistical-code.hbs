<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Geographic Statistical Code Report</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            font-size: 10pt;
            line-height: 1.4;
            color: #333;
            padding: 20px;
        }

        .cover-page {
            text-align: center;
            padding: 100px 20px;
            page-break-after: always;
        }

        .cover-page h1 {
            font-size: 28pt;
            margin-bottom: 30px;
            color: #2c3e50;
        }

        .cover-page .subtitle {
            font-size: 14pt;
            color: #7f8c8d;
            margin-bottom: 50px;
        }

        .cover-page .stats {
            margin-top: 60px;
            display: inline-block;
            text-align: left;
        }

        .cover-page .stats-row {
            margin: 15px 0;
            font-size: 12pt;
        }

        .cover-page .stats-label {
            display: inline-block;
            width: 200px;
            font-weight: bold;
        }

        .dzongkhag-section {
            page-break-before: always;
            margin-bottom: 30px;
        }

        .dzongkhag-header {
            background-color: #34495e;
            color: white;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
        }

        .dzongkhag-header h2 {
            font-size: 18pt;
            margin: 0;
        }

        .dzongkhag-header .code {
            font-size: 12pt;
            margin-top: 5px;
            opacity: 0.9;
        }

        .summary-table {
            width: 100%;
            margin-bottom: 25px;
            border-collapse: collapse;
        }

        .summary-table th,
        .summary-table td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }

        .summary-table th {
            background-color: #ecf0f1;
            font-weight: bold;
        }

        .summary-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .section-title {
            font-size: 14pt;
            font-weight: bold;
            margin: 20px 0 10px 0;
            color: #2c3e50;
            border-bottom: 2px solid #3498db;
            padding-bottom: 5px;
        }

        .ea-table {
            width: 100%;
            margin-bottom: 25px;
            border-collapse: collapse;
            font-size: 9pt;
        }

        .ea-table th,
        .ea-table td {
            border: 1px solid #ddd;
            padding: 6px;
            text-align: left;
        }

        .ea-table th {
            background-color: #3498db;
            color: white;
            font-weight: bold;
        }

        .ea-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .ea-table tr:hover {
            background-color: #e8f4f8;
        }

        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 8pt;
            color: #7f8c8d;
            padding: 10px;
            border-top: 1px solid #ddd;
        }

        .page-number {
            margin-top: 20px;
            text-align: center;
            font-size: 9pt;
            color: #7f8c8d;
        }

        @media print {
            .dzongkhag-section {
                page-break-inside: avoid;
            }

            .ea-table {
                page-break-inside: auto;
            }

            .ea-table tr {
                page-break-inside: avoid;
                page-break-after: auto;
            }
        }
    </style>
</head>
<body>
    <!-- Cover Page -->
    <div class="cover-page">
        <h1>Geographic Statistical Code Report</h1>
        <div class="subtitle">National Statistical Field Database</div>
        <div class="subtitle">Generated: {{generatedDate}}</div>
        
        <div class="stats">
            <div class="stats-row">
                <span class="stats-label">Total Dzongkhags:</span>
                <span>{{totalDzongkhags}}</span>
            </div>
            <div class="stats-row">
                <span class="stats-label">Total Enumeration Areas:</span>
                <span>{{totalEAs}}</span>
            </div>
            <div class="stats-row">
                <span class="stats-label">Urban EAs:</span>
                <span>{{totalUrbanEAs}}</span>
            </div>
            <div class="stats-row">
                <span class="stats-label">Rural EAs:</span>
                <span>{{totalRuralEAs}}</span>
            </div>
        </div>
    </div>

    <!-- Dzongkhag Sections -->
    {{#each dzongkhags}}
    <div class="dzongkhag-section">
        <div class="dzongkhag-header">
            <h2>{{name}}</h2>
            <div class="code">Code: {{code}}</div>
        </div>

        <!-- Summary Table -->
        <table class="summary-table">
            <thead>
                <tr>
                    <th>Gewogs</th>
                    <th>Thromdes</th>
                    <th>Chiwogs</th>
                    <th>LAPs</th>
                    <th>Total EAs</th>
                    <th>Urban EAs</th>
                    <th>Rural EAs</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>{{summary.totalGewogs}}</td>
                    <td>{{summary.totalThromdes}}</td>
                    <td>{{summary.totalChiwogs}}</td>
                    <td>{{summary.totalLaps}}</td>
                    <td>{{summary.totalEAs}}</td>
                    <td>{{summary.urbanEAs}}</td>
                    <td>{{summary.ruralEAs}}</td>
                </tr>
            </tbody>
        </table>

        <!-- Urban EAs Section -->
        {{#if urbanEAs}}
        <div class="section-title">Urban Enumeration Areas</div>
        <table class="ea-table">
            <thead>
                <tr>
                    <th>Thromde</th>
                    <th>Thromde Code</th>
                    <th>LAP</th>
                    <th>LAP Code</th>
                    <th>EA Name</th>
                    <th>EA Code</th>
                </tr>
            </thead>
            <tbody>
                {{#each urbanEAs}}
                <tr>
                    <td>{{administrativeZone.name}}</td>
                    <td>{{administrativeZone.code}}</td>
                    <td>{{subAdministrativeZone.name}}</td>
                    <td>{{subAdministrativeZone.code}}</td>
                    <td>{{eaName}}</td>
                    <td>{{eaCode}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        {{/if}}

        <!-- Rural EAs Section -->
        {{#if ruralEAs}}
        <div class="section-title">Rural Enumeration Areas</div>
        <table class="ea-table">
            <thead>
                <tr>
                    <th>Gewog</th>
                    <th>Gewog Code</th>
                    <th>Chiwog</th>
                    <th>Chiwog Code</th>
                    <th>EA Name</th>
                    <th>EA Code</th>
                </tr>
            </thead>
            <tbody>
                {{#each ruralEAs}}
                <tr>
                    <td>{{administrativeZone.name}}</td>
                    <td>{{administrativeZone.code}}</td>
                    <td>{{subAdministrativeZone.name}}</td>
                    <td>{{subAdministrativeZone.code}}</td>
                    <td>{{eaName}}</td>
                    <td>{{eaCode}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        {{/if}}
    </div>
    {{/each}}

    <div class="footer">
        <p>Geographic Statistical Code Report - Generated {{generatedDate}} | © {{currentYear}} National Statistical Field Database</p>
    </div>
</body>
</html>

