<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bhutan Administrative Map</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8f9fa;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            padding: 15mm;
            background: white;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        /* Header Section */
        .header {
            text-align: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 3px solid #ff6600;
        }

        .header h1 {
            color: #2c3e50;
            font-size: 28px;
            margin-bottom: 5px;
            font-weight: 700;
        }

        .header .subtitle {
            color: #7f8c8d;
            font-size: 14px;
            font-weight: 400;
        }

        .header .logo {
            width: 60px;
            height: 60px;
            margin: 0 auto 10px;
        }

        /* Map Container */
        #map {
            width: 100%;
            height: 500px;
            border: 2px solid #dee2e6;
            border-radius: 8px;
            margin: 20px 0;
            position: relative;
        }

        /* Map Title Box */
        .map-title-box {
            position: absolute;
            top: 10px;
            left: 10px;
            background: white;
            padding: 15px 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            z-index: 1000;
            border-left: 4px solid #ff6600;
        }

        .map-title-box h2 {
            font-size: 18px;
            color: #2c3e50;
            margin-bottom: 5px;
        }

        .map-title-box p {
            font-size: 12px;
            color: #7f8c8d;
            margin: 0;
        }

        /* Legend */
        .legend {
            position: absolute;
            bottom: 20px;
            right: 10px;
            background: white;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            z-index: 1000;
            min-width: 200px;
        }

        .legend h4 {
            margin: 0 0 10px 0;
            font-size: 14px;
            color: #2c3e50;
            border-bottom: 2px solid #ff6600;
            padding-bottom: 5px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
            font-size: 12px;
        }

        .legend-color {
            width: 30px;
            height: 20px;
            margin-right: 10px;
            border: 1px solid #dee2e6;
            border-radius: 3px;
        }

        /* Scale Bar */
        .scale-bar {
            position: absolute;
            bottom: 20px;
            left: 10px;
            background: white;
            padding: 8px 12px;
            border-radius: 5px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            z-index: 1000;
            font-size: 11px;
        }

        /* North Arrow */
        .north-arrow {
            position: absolute;
            top: 80px;
            right: 10px;
            background: white;
            padding: 10px;
            border-radius: 50%;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            z-index: 1000;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            color: #2c3e50;
        }

        /* Statistics Section */
        .stats-section {
            margin-top: 20px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
        }

        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
        }

        .stat-card.orange {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }

        .stat-card.green {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }

        .stat-card.blue {
            background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        }

        .stat-value {
            font-size: 32px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 12px;
            opacity: 0.9;
        }

        /* Dzongkhag List */
        .dzongkhag-list {
            margin-top: 20px;
        }

        .dzongkhag-list h3 {
            color: #2c3e50;
            font-size: 18px;
            margin-bottom: 15px;
            padding-bottom: 8px;
            border-bottom: 2px solid #ff6600;
        }

        .dzongkhag-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .dzongkhag-item {
            background: #f8f9fa;
            padding: 12px;
            border-radius: 6px;
            border-left: 3px solid #667eea;
            font-size: 13px;
        }

        .dzongkhag-item .name {
            font-weight: 600;
            color: #2c3e50;
        }

        .dzongkhag-item .code {
            color: #7f8c8d;
            font-size: 11px;
        }

        /* Footer */
        .footer {
            margin-top: 30px;
            padding-top: 15px;
            border-top: 2px solid #dee2e6;
            text-align: center;
            color: #7f8c8d;
            font-size: 11px;
        }

        .footer .date {
            margin-bottom: 5px;
        }

        /* Coordinate Display */
        .coordinates {
            position: absolute;
            bottom: 50px;
            left: 10px;
            background: white;
            padding: 5px 10px;
            border-radius: 5px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            z-index: 1000;
            font-size: 10px;
            color: #2c3e50;
        }

        /* Leaflet Custom Styles */
        .leaflet-popup-content-wrapper {
            border-radius: 8px;
            box-shadow: 0 3px 14px rgba(0,0,0,0.4);
        }

        .leaflet-popup-content {
            margin: 15px;
            font-size: 13px;
        }

        .popup-title {
            font-weight: bold;
            font-size: 14px;
            color: #2c3e50;
            margin-bottom: 8px;
        }

        .popup-info {
            color: #7f8c8d;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="page">
        <!-- Header -->
        <div class="header">
            <div class="logo">
                <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="50" r="45" fill="#ff6600" opacity="0.2"/>
                    <path d="M 50 10 L 60 40 L 90 40 L 65 60 L 75 90 L 50 70 L 25 90 L 35 60 L 10 40 L 40 40 Z" fill="#ff6600"/>
                </svg>
            </div>
            <h1>KINGDOM OF BHUTAN</h1>
            <div class="subtitle">Administrative Divisions Map - Dzongkhags</div>
            <div class="subtitle">National Statistics Bureau</div>
        </div>

        <!-- Map -->
        <div id="map">
            <!-- Map Title Box -->
            <div class="map-title-box">
                <h2>20 Dzongkhags of Bhutan</h2>
                <p>Administrative Boundaries</p>
            </div>

            <!-- North Arrow -->
            <div class="north-arrow">⬆<br><small style="font-size:8px;">N</small></div>

            <!-- Legend -->
            <div class="legend">
                <h4>Legend</h4>
                <div class="legend-item">
                    <div class="legend-color" style="background: rgba(102, 126, 234, 0.4); border: 2px solid #667eea;"></div>
                    <span>Dzongkhag Boundary</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #667eea;"></div>
                    <span>Selected/Highlighted</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: rgba(255, 102, 0, 0.3); border: 2px solid #ff6600;"></div>
                    <span>Hover State</span>
                </div>
                <hr style="margin: 10px 0; border: none; border-top: 1px solid #dee2e6;">
                <div style="font-size: 10px; color: #7f8c8d; margin-top: 8px;">
                    <strong>Coordinate System:</strong><br>
                    WGS 84 (EPSG:4326)
                </div>
            </div>

            <!-- Scale Bar -->
            <div class="scale-bar">
                Scale: 1:1,000,000 (approx)
            </div>

            <!-- Coordinates Display -->
            <div class="coordinates" id="coordinates">
                Lat: 27.5° N, Lng: 90.5° E
            </div>
        </div>

        <!-- Statistics -->
        <div class="stats-section">
            <div class="stat-card">
                <div class="stat-value">{{totalDzongkhags}}</div>
                <div class="stat-label">Total Dzongkhags</div>
            </div>
            <div class="stat-card orange">
                <div class="stat-value">{{totalArea}}</div>
                <div class="stat-label">Total Area (sq km)</div>
            </div>
            <div class="stat-card green">
                <div class="stat-value">{{totalAdminZones}}</div>
                <div class="stat-label">Administrative Zones</div>
            </div>
            <div class="stat-card blue">
                <div class="stat-value">{{totalEAs}}</div>
                <div class="stat-label">Enumeration Areas</div>
            </div>
        </div>

        <!-- Dzongkhag List -->
        <div class="dzongkhag-list">
            <h3>List of Dzongkhags</h3>
            <div class="dzongkhag-grid">
                {{#each dzongkhags}}
                <div class="dzongkhag-item">
                    <div class="name">{{this.name}}</div>
                    <div class="code">Code: {{this.areaCode}} | {{this.areaSqKm}} sq km</div>
                </div>
                {{/each}}
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <div class="date">Generated on: {{generatedDate}}</div>
            <div>© {{currentYear}} National Statistics Bureau, Kingdom of Bhutan</div>
            <div style="margin-top: 5px;">Data Source: NSFD Backend System | Projection: WGS 84</div>
        </div>
    </div>

    <script>
        // Initialize map
        const map = L.map('map', {
            center: [27.5, 90.5],
            zoom: 8,
            zoomControl: true,
            attributionControl: false
        });

        // Add base layer (OpenStreetMap)
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // Add custom attribution
        L.control.attribution({
            position: 'bottomright',
            prefix: 'NSB © 2025'
        }).addTo(map);

        // GeoJSON data
        const geojsonData = {{{geojsonData}}};

        // Color palette for dzongkhags
        const colors = [
            '#667eea', '#764ba2', '#f093fb', '#f5576c',
            '#4facfe', '#00f2fe', '#43e97b', '#38f9d7',
            '#fa709a', '#fee140', '#30cfd0', '#330867',
            '#a8edea', '#fed6e3', '#ff6a00', '#ee0979',
            '#f857a6', '#ff5858', '#56ab2f', '#a8e063'
        ];

        // Style function for each feature
        function style(feature) {
            const index = geojsonData.features.indexOf(feature) % colors.length;
            return {
                fillColor: colors[index],
                weight: 2,
                opacity: 1,
                color: '#2c3e50',
                dashArray: '',
                fillOpacity: 0.5
            };
        }

        // Highlight feature on hover
        function highlightFeature(e) {
            const layer = e.target;
            layer.setStyle({
                weight: 3,
                color: '#ff6600',
                dashArray: '',
                fillOpacity: 0.7
            });
            layer.bringToFront();

            // Update coordinates display
            const latlng = e.latlng;
            document.getElementById('coordinates').innerHTML = 
                `Lat: ${latlng.lat.toFixed(4)}°, Lng: ${latlng.lng.toFixed(4)}°`;
        }

        // Reset highlight
        function resetHighlight(e) {
            geojsonLayer.resetStyle(e.target);
        }

        // Popup on click
        function onEachFeature(feature, layer) {
            const props = feature.properties;
            const popupContent = `
                <div class="popup-title">${props.name}</div>
                <div class="popup-info">
                    <strong>Area Code:</strong> ${props.areaCode}<br>
                    <strong>Area:</strong> ${props.areaSqKm} sq km<br>
                    <strong>ID:</strong> ${props.id}
                </div>
            `;
            
            layer.bindPopup(popupContent);
            
            layer.on({
                mouseover: highlightFeature,
                mouseout: resetHighlight
            });
        }

        // Add GeoJSON layer
        const geojsonLayer = L.geoJSON(geojsonData, {
            style: style,
            onEachFeature: onEachFeature
        }).addTo(map);

        // Fit map to bounds
        map.fitBounds(geojsonLayer.getBounds(), {
            padding: [20, 20]
        });

        // Add scale control
        L.control.scale({
            position: 'bottomleft',
            imperial: false,
            metric: true
        }).addTo(map);

        // Wait for map to fully render before PDF generation
        setTimeout(() => {
            window.mapReady = true;
        }, 2000);
    </script>
</body>
</html>
