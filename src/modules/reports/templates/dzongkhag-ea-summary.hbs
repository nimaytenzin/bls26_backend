<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dzongkhag EA Summary Report</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            font-size: 10pt;
            line-height: 1.4;
            color: #333;
            padding: 20px;
        }

        .cover-page {
            text-align: center;
            padding: 100px 20px;
            page-break-after: always;
        }

        .cover-page h1 {
            font-size: 28pt;
            margin-bottom: 30px;
            color: #2c3e50;
        }

        .cover-page .subtitle {
            font-size: 14pt;
            color: #7f8c8d;
            margin-bottom: 50px;
        }

        .cover-page .stats {
            margin-top: 60px;
            display: inline-block;
            text-align: left;
        }

        .cover-page .stats-row {
            margin: 15px 0;
            font-size: 12pt;
        }

        .cover-page .stats-label {
            display: inline-block;
            width: 200px;
            font-weight: bold;
        }

        .map-section {
            page-break-before: always;
            margin-bottom: 30px;
        }

        .map-header {
            background-color: #34495e;
            color: white;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
        }

        .map-header h2 {
            font-size: 18pt;
            margin: 0;
        }

        #map {
            width: 100%;
            height: 500px;
            border: 2px solid #ddd;
            border-radius: 5px;
            margin-bottom: 20px;
        }

        .legend {
            background: white;
            padding: 15px;
            border-radius: 5px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            margin-bottom: 20px;
        }

        .legend h4 {
            margin-bottom: 10px;
            font-size: 12pt;
        }

        .legend-item {
            display: flex;
            align-items: center;
            margin: 8px 0;
        }

        .legend-color {
            width: 20px;
            height: 20px;
            margin-right: 10px;
            border: 1px solid #ddd;
        }

        .summary-table {
            width: 100%;
            margin-bottom: 25px;
            border-collapse: collapse;
        }

        .summary-table th,
        .summary-table td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }

        .summary-table th {
            background-color: #ecf0f1;
            font-weight: bold;
        }

        .summary-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .gewog-section {
            page-break-before: always;
            margin-bottom: 30px;
        }

        .gewog-header {
            background-color: #3498db;
            color: white;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
        }

        .gewog-header h3 {
            font-size: 16pt;
            margin: 0;
        }

        .chiwog-section {
            margin-left: 20px;
            margin-bottom: 20px;
        }

        .chiwog-header {
            background-color: #95a5a6;
            color: white;
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 3px;
        }

        .chiwog-header h4 {
            font-size: 12pt;
            margin: 0;
        }

        .ea-table {
            width: 100%;
            margin-bottom: 25px;
            border-collapse: collapse;
            font-size: 9pt;
        }

        .ea-table th,
        .ea-table td {
            border: 1px solid #ddd;
            padding: 6px;
            text-align: left;
        }

        .ea-table th {
            background-color: #3498db;
            color: white;
            font-weight: bold;
        }

        .ea-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 8pt;
            color: #7f8c8d;
            padding: 10px;
            border-top: 1px solid #ddd;
        }

        @media print {
            .gewog-section {
                page-break-inside: avoid;
            }

            .ea-table {
                page-break-inside: auto;
            }

            .ea-table tr {
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body>
    <!-- Cover Page -->
    <div class="cover-page">
        <h1>Dzongkhag EA Summary Report</h1>
        <div class="subtitle">National Statistical Field Database</div>
        <div class="subtitle">{{dzongkhag.name}} ({{dzongkhag.code}})</div>
        <div class="subtitle">Generated: {{generatedDate}}</div>
        
        <div class="stats">
            <div class="stats-row">
                <span class="stats-label">Total Gewogs:</span>
                <span>{{summary.totalGewogs}}</span>
            </div>
            <div class="stats-row">
                <span class="stats-label">Total Chiwogs:</span>
                <span>{{summary.totalChiwogs}}</span>
            </div>
            <div class="stats-row">
                <span class="stats-label">Total Enumeration Areas:</span>
                <span>{{summary.totalEAs}}</span>
            </div>
        </div>
    </div>

    <!-- Map Section -->
    <div class="map-section">
        <div class="map-header">
            <h2>Geographic Boundaries Map</h2>
        </div>
        <div id="map"></div>
        <div class="legend">
            <h4>Legend</h4>
            <div class="legend-item">
                <div class="legend-color" style="background: rgba(52, 152, 219, 0.3); border: 3px solid #3498db;"></div>
                <span>Dzongkhag Boundary</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: rgba(46, 204, 113, 0.3); border: 2px solid #2ecc71;"></div>
                <span>Gewog Boundary</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: rgba(231, 76, 60, 0.3); border: 1px solid #e74c3c;"></div>
                <span>Enumeration Area Boundary</span>
            </div>
        </div>
    </div>

    <!-- Summary Table -->
    <div class="gewog-section">
        <h2 style="margin-bottom: 20px;">Summary by Gewog</h2>
        <table class="summary-table">
            <thead>
                <tr>
                    <th>Gewog Name</th>
                    <th>Gewog Code</th>
                    <th>Chiwogs</th>
                    <th>Enumeration Areas</th>
                </tr>
            </thead>
            <tbody>
                {{#each gewogs}}
                <tr>
                    <td>{{name}}</td>
                    <td>{{code}}</td>
                    <td>{{summary.totalChiwogs}}</td>
                    <td>{{summary.totalEAs}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    <!-- Gewog Sections -->
    {{#each gewogs}}
    <div class="gewog-section">
        <div class="gewog-header">
            <h3>{{name}} ({{code}})</h3>
        </div>

        {{#each chiwogs}}
        <div class="chiwog-section">
            <div class="chiwog-header">
                <h4>{{name}} ({{code}})</h4>
            </div>

            <table class="ea-table">
                <thead>
                    <tr>
                        <th>EA Name</th>
                        <th>EA Code</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each enumerationAreas}}
                    <tr>
                        <td>{{name}}</td>
                        <td>{{code}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{/each}}
    </div>
    {{/each}}

    <div class="footer">
        <p>Dzongkhag EA Summary Report - Generated {{generatedDate}} | © {{currentYear}} National Statistical Field Database</p>
    </div>

    <script id="map-data" type="application/json">{{mapData}}</script>
    <script>
        // Initialize map after page load
        window.addEventListener('load', function() {
            try {
                // Get map data from script tag
                const mapDataScript = document.getElementById('map-data');
                const mapData = JSON.parse(mapDataScript.textContent);
                
                // Create map centered on Bhutan
                const map = L.map('map', {
                    zoomControl: true,
                    attributionControl: true
                }).setView([27.5, 90.5], 8);

                // Add base tile layer
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap contributors',
                    maxZoom: 19
                }).addTo(map);

                // Create a GeoJSON layer with all features
                const geoJsonLayer = L.geoJSON(mapData, {
                    style: function(feature) {
                        const props = feature.properties || {};
                        const layerType = props.layer;
                        
                        if (layerType === 'dzongkhag') {
                            return {
                                color: '#3498db',
                                weight: 3,
                                fillColor: '#3498db',
                                fillOpacity: 0.3
                            };
                        } else if (layerType === 'gewog') {
                            return {
                                color: '#2ecc71',
                                weight: 2,
                                fillColor: '#2ecc71',
                                fillOpacity: 0.3
                            };
                        } else {
                            return {
                                color: '#e74c3c',
                                weight: 1,
                                fillColor: '#e74c3c',
                                fillOpacity: 0.2
                            };
                        }
                    },
                    onEachFeature: function(feature, layer) {
                        const props = feature.properties || {};
                        const popupContent = '<div>' +
                            '<strong>' + (props.name || '') + '</strong><br>' +
                            'Code: ' + (props.code || '') + '<br>' +
                            'Type: ' + (props.layer || '') +
                            '</div>';
                        layer.bindPopup(popupContent);
                    }
                }).addTo(map);

                // Fit map to bounds
                if (mapData && mapData.features && mapData.features.length > 0) {
                    setTimeout(function() {
                        map.fitBounds(geoJsonLayer.getBounds(), { padding: [50, 50] });
                    }, 1000);
                }
            } catch (error) {
                console.error('Error initializing map:', error);
                // Show error message in map container
                document.getElementById('map').innerHTML = 
                    '<div style="padding: 20px; text-align: center; color: #e74c3c;">' +
                    'Map could not be loaded. Please check the console for details.' +
                    '</div>';
            }
        });
    </script>
</body>
</html>
